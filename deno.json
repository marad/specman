{
  "tasks": {
    "dev": "deno run --watch -A cli.ts",
    "test": "deno test --allow-read",
    "compile": "deno compile --allow-read --allow-write --allow-run --output specman cli.ts",
    "install": "deno compile --allow-read --allow-write --allow-run --output ~/.local/bin/specman cli.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/yaml": "jsr:@std/yaml@1",
    "@std/path": "jsr:@std/path@1"
  }
}
